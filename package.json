{
  "name": "pokemon-duel",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20.19.1"
  },
  "scripts": {
    "client": "nx serve client",
    "server": "nx serve server",
    "build": "nx run-many -t build",
    "build:client": "nx build client --configuration=production",
    "build:server": "nx publish server",
    "test": "nx run-many -t test",
    "e2e": "nx run-many -t e2e",
    "lint": "nx run-many -t lint",
    "affected": "nx affected",
    "graph": "nx graph",
    "deploy": "nx run-many -t deploy --projects=server,client",
    "deploy:client": "nx deploy client",
    "deploy:server": "nx deploy server",
    "firebase:login": "firebase login",
    "gcloud:login": "gcloud auth login"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular/animations": "21.2.6",
    "@angular/cdk": "21.2.4",
    "@angular/common": "21.2.6",
    "@angular/compiler": "21.2.6",
    "@angular/core": "21.2.6",
    "@angular/forms": "21.2.6",
    "@angular/material": "21.2.4",
    "@angular/platform-browser": "21.2.6",
    "@angular/platform-browser-dynamic": "21.2.6",
    "@angular/router": "21.2.6",
    "@microsoft/signalr": "^10.0.0",
    "@ngrx/signals": "^21.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@analogjs/vitest-angular": "^2.2.3",
    "@angular/build": "21.2.5",
    "@angular/cli": "21.2.5",
    "@angular/compiler-cli": "21.2.6",
    "@noble/hashes": "^2.0.1",
    "@nx/angular": "22.6.2",
    "@nx/playwright": "22.6.2",
    "@nx/vite": "22.6.2",
    "@nx/vitest": "^22.6.2",
    "@nx/workspace": "22.6.2",
    "@playwright/test": "^1.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^27.1.0",
    "nx": "22.6.2",
    "typescript": "~5.9.2",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "^4.0.8"
  }
}
